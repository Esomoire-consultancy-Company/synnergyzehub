# Synnergyze Seed Node v0.1
# Copy to .env on your VM. Do not commit real secrets.

ENVIRONMENT=development

# Database
POSTGRES_USER=synnergyze
POSTGRES_PASSWORD=change_me
POSTGRES_DB=synnergyze_seed
DATABASE_URL=postgresql://synnergyze:change_me@postgres:5432/synnergyze_seed

# MinIO / object storage
MINIO_ROOT_USER=synnergyze
MINIO_ROOT_PASSWORD=change_me
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=synnergyze
MINIO_SECRET_KEY=change_me

# OpenAI backend key
# Never expose this in browser/mobile apps.
OPENAI_API_KEY=put_key_only_on_server_or_secret_manager

# Client instance metadata
CLIENT_INSTANCE_ID=seed-node-local
CLIENT_NAME=Synnergyze Seed Node
CLIENT_MODE=internal
GITHUB_REPOSITORY_OWNER=
GITHUB_REPOSITORY_NAME=
